{
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": [
      "/css/*",
      "/images/*",
      "/js/*",
      "*.ico",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.svg",
      "*.webp",
      "*.woff",
      "*.woff2",
      "*.ttf",
      "*.eot"
    ]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
